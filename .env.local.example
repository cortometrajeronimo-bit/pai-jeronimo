# =====================================
# P.A.I. JERÓNIMO — Variables de entorno
# Copia este archivo a .env.local y completa
# =====================================

# Supabase — obtener en https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Solo server (NO exponer): para seed inicial y operaciones admin
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# IA — provider gratuito por defecto
# Crear cuenta en https://groq.com → Settings → API Keys → "Create API Key"
# Free tier: ~30 req/min sobre Llama 3.3 70B (suficiente para uso individual)
LLM_PROVIDER=groq
GROQ_API_KEY=
# Sin key → el chat entra en modo demo con respuestas predefinidas

# Anthropic / Kimi (opcionales — sin uso por ahora)
# ANTHROPIC_API_KEY=
# KIMI_API_KEY=

# Email (Fase 3)
RESEND_API_KEY=
EMAIL_FROM=daniel@pai-jeronimo.com

# =====================================
# Google Drive — Service Account (Fase 3 / T18)
# 1. Crear proyecto en https://console.cloud.google.com
# 2. Habilitar Google Drive API + Google Docs API + Google Sheets API
# 3. IAM → Service Accounts → Create → descargar JSON
# 4. Pegar el client_email aquí ↓ y la private_key (con \n literales) ↓
# 5. En Drive, compartir la carpeta raíz del proyecto con el client_email (Lector)
# 6. Copiar el ID de la carpeta (parte final de la URL en Drive)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Sin estas vars el módulo Drive corre en modo demo con archivos mock
